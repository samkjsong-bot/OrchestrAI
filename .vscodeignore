# 소스·설정
src/**
tsconfig.json
.vscode/**
.vscode-test/**
.github/**
작업실/**
test/**
_fix_*.py
_diag*.py
_probe_*.js
_verify.py
.gitignore
.eslintrc*
.prettierrc*

# VSIX 자체
*.vsix

# 개발 부속
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/__tests__/**
node_modules/**/__test__/**
node_modules/**/docs/**
node_modules/**/doc/**
node_modules/**/examples/**
node_modules/**/example/**
node_modules/**/*.md
node_modules/**/*.map
node_modules/**/*.ts
node_modules/**/.github/**
node_modules/**/CHANGELOG*
node_modules/**/HISTORY*
node_modules/**/LICENSE*
node_modules/**/AUTHORS*
node_modules/**/NOTICE*
node_modules/**/.npmignore
node_modules/**/.editorconfig
node_modules/**/.eslintrc*
node_modules/**/.prettierrc*
node_modules/**/tsconfig*.json
node_modules/**/rollup.config*
node_modules/**/vite.config*
node_modules/**/vitest.config*

# types 패키지 불필요 (dev에서만 씀)
node_modules/@types/**

# 큰 선택 의존성 (나중에 필요 시 제거)
node_modules/**/*.wasm.map

# NOTE: Claude Agent SDK의 vendor/ripgrep은 포함해야 Grep·Glob 툴 동작함. 제외 금지.

# 사용 안 하는 거대한 transitive deps (gemini-cli-core / claude-agent-sdk가 lazy로 가져왔는데 우리 코드는 안 씀)
node_modules/googleapis/**
node_modules/googleapis-common/**
node_modules/node-pty/**
node_modules/tree-sitter-bash/**
node_modules/web-tree-sitter/**
node_modules/@img/**
# @opentelemetry: ai 패키지가 @opentelemetry/api 만 import하므로 무거운 sub만 제외
# (api 2.6M / api-logs 524K / core / resources 등은 유지)
node_modules/@opentelemetry/exporter-*/**
node_modules/@opentelemetry/sdk-*/**
node_modules/@opentelemetry/otlp-*/**
node_modules/@opentelemetry/semantic-conventions/**
node_modules/@opentelemetry/instrumentation*/**
node_modules/@opentelemetry/propagator-*/**
node_modules/@opentelemetry/resource-detector*/**
# Native 빌드 도구
node_modules/node-gyp-build/**
node_modules/@mapbox/node-pre-gyp/**
node_modules/prebuild-install/**
# Sourcemap·debug 관련
node_modules/**/*.d.ts
node_modules/**/*.flow
node_modules/**/Makefile
node_modules/**/binding.gyp
